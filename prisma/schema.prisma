// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// =====================
// ENUMS
// =====================

enum Role {
  ADMIN
  DEPARTMENT
  PROJECT_MANAGER
  TEAM_MEMBER
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  NEGOTIATION
  WON
  LOST
}

enum PropertyStatus {
  AVAILABLE
  SOLD
  RENTED
}

enum PropertyType {
  Residential
  Agricultural
  Commercial
}

// =====================
// USER & ROLE
// =====================

model User {
  id       Int    @id @default(autoincrement())
  name     String
  email    String @unique
  password String
  role     Role

  departmentId Int?
  department   Department? @relation(fields: [departmentId], references: [id])

  createdLeads  Lead[] @relation("CreatedBy")
  assignedLeads Lead[] @relation("AssignedTo")

  properties Property[] @relation("CreatedProperties")

  createdAt  DateTime   @default(now())
  activities Activity[]
}

// =====================
// DEPARTMENT
// =====================

model Department {
  id   Int    @id @default(autoincrement())
  name String

  users User[]
  leads Lead[]

  createdAt DateTime @default(now())
}

// =====================
// LEADS
// =====================

model Lead {
  id    Int     @id @default(autoincrement())
  name  String
  phone String
  email String?

  status LeadStatus @default(NEW)
  source String? // facebook, website etc

  departmentId Int?
  department   Department? @relation(fields: [departmentId], references: [id])

  createdById Int
  createdBy   User @relation("CreatedBy", fields: [createdById], references: [id])

  assignedToId Int?
  assignedTo   User? @relation("AssignedTo", fields: [assignedToId], references: [id])

  notes String?

  activities Activity[]

  createdAt DateTime @default(now())
}

// =====================
// PROPERTIES
// =====================

model Property {
  id          Int     @id @default(autoincrement())
  title       String
  description String?

  price    Float
  location String

  propertyType String

  status PropertyStatus @default(AVAILABLE)

  createdById Int
  createdBy   User @relation("CreatedProperties", fields: [createdById], references: [id])

  images          PropertyImage[]
  specification   Specification[]
  propertyAmenity PropertyAmenity[]

  createdAt DateTime @default(now())
}

// =====================
// PROPERTY SPECIFICATION
// =====================
model Specification {
  id    Int    @id @default(autoincrement())
  key   String // "Area", "PricePerSqFt"
  value String // "1 Acre", "₹115"

  propertyId Int
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

// =====================
// AMENITIES MASTER
// =====================

model Amenity {
  id   Int    @id @default(autoincrement())
  name String @unique // Parking, Pool, Garden

  properties PropertyAmenity[]
}

// =====================
// PROPERTY ↔ AMENITIES (Many-to-Many)
// =====================

model PropertyAmenity {
  id Int @id @default(autoincrement())

  propertyId Int
  amenityId  Int

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  amenity  Amenity  @relation(fields: [amenityId], references: [id])

  @@unique([propertyId, amenityId])
}

// =====================
// PROPERTY IMAGES
// =====================

model PropertyImage {
  id  Int    @id @default(autoincrement())
  url String

  propertyId Int
  property   Property @relation(fields: [propertyId], references: [id])
}

// =====================
// ACTIVITIES (Lead Tracking)
// =====================

model Activity {
  id   Int     @id @default(autoincrement())
  type String // call, meeting, follow-up
  note String?

  leadId Int
  lead   Lead @relation(fields: [leadId], references: [id])

  createdById Int
  createdBy   User @relation(fields: [createdById], references: [id])

  createdAt DateTime @default(now())
}
